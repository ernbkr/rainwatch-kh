{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rainwatch KH",
  "version": "0.1.0",
  "identifier": "com.eob.rainwatch-kh",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:vite",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Cambodia Radar",
        "width": 1100,
        "height": 860,
        "minWidth": 720,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: http: https:; style-src 'self' 'unsafe-inline'; script-src 'self'; worker-src blob:; connect-src 'self' ipc: http://ipc.localhost data: blob: http: https:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "nsis", "msi", "app", "dmg"],
    "category": "Weather",
    "shortDescription": "Cambodia Meteo radar viewer",
    "longDescription": "A minimal desktop viewer for Cambodia Meteo radar animations.",
    "publisher": "Erin Baker",
    "copyright": "© 2026 Erin Baker",
    "license": "MIT",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    }
  }
}
