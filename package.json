{
  "name": "cambodia-radar-desktop-viewer",
  "version": "0.1.0",
  "description": "A minimal Linux desktop viewer for Cambodia Meteo radar animations.",
  "main": "src/main.js",
  "scripts": {
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "start:calibrate": "env -u ELECTRON_RUN_AS_NODE electron . --calibrate",
    "test": "vitest run"
  },
  "keywords": [
    "cambodia",
    "radar",
    "electron",
    "weather"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^30.5.1",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "maplibre-gl": "^5.24.0"
  }
}
